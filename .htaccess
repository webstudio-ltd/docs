# ╔══════════════════════════════════════════════════════════╗
# ║  Webstudio Docs — .htaccess                              ║
# ║  Apache security rules                                    ║
# ╚══════════════════════════════════════════════════════════╝

# Block direct access to data directory and JSON files
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^data/ - [F,L]
</IfModule>

# Block access to .json files anywhere
<FilesMatch "\.json$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to auth.php internals (only POST/GET via fetch should work)
# This doesn't block API calls, just direct browsing of sensitive patterns

# Prevent directory listing
Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
